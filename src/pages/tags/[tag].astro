---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import BackToTop from '../../components/BackToTop.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { slugify } from '../../utils/slugify';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	
	// Get all unique tags
	const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];
	
	return uniqueTags.map((tag) => {
		const filteredPosts = allPosts
			.filter((post) => post.data.tags.includes(tag))
			.sort((a, b) => new Date(b.data.time).valueOf() - new Date(a.data.time).valueOf());
		
		return {
			params: { tag: slugify(tag) },
			props: { posts: filteredPosts, tagName: tag },
		};
	});
}

const { tag } = Astro.params;
const { posts, tagName } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`标签：${tagName} - ${SITE_TITLE}`} description={`所有带有"${tagName}"标签的文章`} />
		<style>
			main {
				width: 720px;
			}
			.tag-header {
				text-align: center;
				margin-bottom: 3rem;
			}
			.tag-header h1 {
				margin-bottom: 0.5rem;
				font-size: 3rem;
			}
			.tag-header .subtitle {
				color: var(--footer-text);
				font-size: 1.2rem;
				margin: 0;
			}
			.tag-badge {
				display: inline-block;
				padding: 0.5rem 1.5rem;
				background: var(--accent);
				color: white;
				border-radius: 9999px;
				font-size: 1.25rem;
				font-weight: 600;
				margin: 1rem 0;
			}
			:global([data-theme="dark"]) .tag-badge {
				color: white;
			}

			.post-item {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				padding: 0.6rem 0;
				text-decoration: none;
				color: var(--text-color);
			}
			.post-line {
				flex: 1;
				height: 1px;
				background: var(--border-color);
				transition: background 0.2s ease;
			}
			.post-item:hover .post-line {
				background: var(--text);
			}
			.post-title {
				font-size: 1.125rem;
				line-height: 1.5;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
				flex-shrink: 1;
				min-width: 0;
			}
			.post-date {
				color: var(--text-muted);
				font-size: 0.9rem;
				font-weight: 500;
				white-space: nowrap;
				flex-shrink: 0;
				transition: color 0.2s ease;
			}
			.post-item:hover .post-date {
				color: var(--text);
			}
			.posts-separator {
				border: none;
				border-top: 1px solid var(--border-color);
				margin: 0;
			}

			@media (max-width: 720px) {
				.tag-header h1 {
					font-size: 2rem;
				}
				.tag-header .subtitle {
					font-size: 1rem;
				}
				.tag-badge {
					font-size: 1rem;
					padding: 0.375rem 1rem;
				}
				.post-title {
					font-size: 1rem;
				}
				.post-date {
					font-size: 0.85rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<section>
				<div class="tag-header">
					<h1>标签</h1>
					<div class="tag-badge">{tagName}</div>
					<p class="subtitle">找到 {posts.length} 篇文章</p>
				</div>
				<div class="post-list">
					{
					   posts.map((post) => (
						   <a href={`/blog/${post.id}`} class="post-item" transition:name={`post-title-${post.id}`}>
							   <span class="post-title">{post.data.title}</span>
							   <div class="post-line"></div>
							   <time class="post-date"><FormattedDate date={post.data.time} /></time>
						   </a>
					   ))
				   }
				   </div>
			</section>
		</main>
		<Footer />
		<BackToTop />
	</body>
</html>