---
import BaseHead from '../components/BaseHead.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { 
	FRIENDS_PAGE_TITLE, 
	FRIENDS_PAGE_DESCRIPTION, 
	FRIENDS_LINKS, 
	BLOG_AGGREGATION_TITLE, 
	BLOG_AGGREGATION_DESCRIPTION, 
	BLOG_AGGREGATIONS,
	SITE_DESCRIPTION,
	SITE_TITLE 
} from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead 
			title={`友情链接 | ${SITE_TITLE}`} 
			description={`${SITE_DESCRIPTION} - 友情链接和博客聚合平台`}
		/>
		<style>
			main {
				width: 720px;
			}
			
			section {
				margin-bottom: 3rem;
			}
			
			section:last-child {
				margin-bottom: 0;
			}
			
			hgroup {
				margin-bottom: 2rem;
				padding: 2rem;
				background: var(--header-bg);
				border-radius: 12px;
				box-shadow: 0 2px 8px rgba(var(--black), 5%);
			}
			
			hgroup h2 {
				font-size: 1.75rem;
				margin-bottom: 0.75rem;
				color: var(--heading-color);
			}
			
			hgroup p {
				color: var(--footer-text);
				font-size: 1rem;
				line-height: 1.6;
			}
			
			.link-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 1.5rem;
			}
			
			.link-card {
				padding: 1.5rem;
				background: var(--header-bg);
				border-radius: 12px;
				box-shadow: 0 2px 8px rgba(var(--black), 5%);
				transition: all 0.3s ease;
				border: 1px solid transparent;
			}
			
			.link-card:hover {
				box-shadow: 0 4px 16px rgba(var(--black), 10%);
				transform: translateY(-2px);
				border-color: var(--border-color);
			}
			
			.link-card-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
				margin-bottom: 0.75rem;
			}
			
			.link-card-header a {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 1.1rem;
				font-weight: 600;
				color: var(--heading-color);
				text-decoration: none;
				transition: color 0.2s ease;
			}
			
			.link-card-header a:hover {
				color: var(--accent);
			}
			
			.link-card-header .external-icon {
				color: var(--footer-text);
				opacity: 0.7;
				transition: opacity 0.2s ease;
			}
			
			.link-card-header a:hover .external-icon {
				opacity: 1;
				color: var(--accent);
			}
			
			.link-inactive {
				display: inline-flex;
				align-items: center;
				padding: 0.25rem 0.75rem;
				background: rgba(var(--black), 5%);
				border-radius: 4px;
				font-size: 0.85rem;
				color: var(--footer-text);
				font-weight: 500;
			}
			
			.link-card p {
				color: var(--footer-text);
				font-size: 0.95rem;
				line-height: 1.6;
				margin: 0;
			}
			
			.divider {
				margin: 3rem 0;
				border: none;
				height: 1px;
				background: linear-gradient(
					to right,
					transparent,
					var(--border-color),
					transparent
				);
			}
			
			@media (max-width: 720px) {
				hgroup {
					padding: 1.5rem;
				}
				
				hgroup h2 {
					font-size: 1.5rem;
				}
				
				.link-card {
					padding: 1.25rem;
				}
				
				.link-card-header a {
					font-size: 1rem;
				}
				
				.link-card p {
					font-size: 0.9rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<Breadcrumb items={[
				{ label: '首页', href: '/' },
				{ label: '链接', href: '/links' }
			]} />
			
			<section>
				<article>
					<hgroup>
						<h2>{FRIENDS_PAGE_TITLE}</h2>
						<p>{FRIENDS_PAGE_DESCRIPTION}</p>
					</hgroup>
					<ul class="link-list">
						{FRIENDS_LINKS.map(link => (
							<li class="link-card">
								<div class="link-card-header">
									<a href={link.site_url} target="_blank" rel="noopener noreferrer">
										{link.site_name}
										{link.is_active !== false ? (
											<svg class="external-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
												<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
												<polyline points="15 3 21 3 21 9" />
												<line x1="10" y1="14" x2="21" y2="3" />
											</svg>
										) : (
											<span class="link-inactive">链接失效</span>
										)}
									</a>
								</div>
								<p>{link.site_description}</p>
							</li>
						))}
					</ul>
				</article>
			</section>
			
			<hr class="divider" />
			
			<section>
				<article>
					<hgroup>
						<h2>{BLOG_AGGREGATION_TITLE}</h2>
						<p>{BLOG_AGGREGATION_DESCRIPTION}</p>
					</hgroup>
					<ul class="link-list">
						{BLOG_AGGREGATIONS.map(link => (
							<li class="link-card">
								<div class="link-card-header">
									<a href={link.site_url} target="_blank" rel="noopener noreferrer">
										{link.site_name}
										<svg class="external-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
											<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
											<polyline points="15 3 21 3 21 9" />
											<line x1="10" y1="14" x2="21" y2="3" />
										</svg>
									</a>
								</div>
								<p>{link.site_description}</p>
							</li>
						))}
					</ul>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>