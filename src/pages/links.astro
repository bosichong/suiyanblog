---
import { readFileSync, existsSync } from 'node:fs';
import BaseHead from '../components/BaseHead.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { 
	FRIENDS_PAGE_TITLE, 
	FRIENDS_PAGE_DESCRIPTION, 
	FRIENDS_LINKS, 
	BLOG_AGGREGATION_TITLE, 
	BLOG_AGGREGATION_DESCRIPTION, 
	BLOG_AGGREGATIONS,
	SITE_DESCRIPTION,
	SITE_TITLE 
} from '../consts';

const RSS_DATA_PATH = 'src/data/rss_data.json';
let rssData = {};
if (existsSync(RSS_DATA_PATH)) {
	rssData = JSON.parse(readFileSync(RSS_DATA_PATH, 'utf-8'));
}

function relativeTime(dateStr: string): string {
	if (!dateStr) return '';
	const now = new Date();
	const pub = new Date(dateStr + 'T00:00:00Z');
	const diff = now.getTime() - pub.getTime();
	const days = Math.floor(diff / 86400000);
	if (days < 0) return '刚刚';
	if (days === 0) return '今天';
	if (days === 1) return '昨天';
	if (days < 7) return `${days}天前`;
	if (days < 30) return `${Math.floor(days / 7)}周前`;
	if (days < 365) return `${Math.floor(days / 30)}个月前`;
	if (Number.isNaN(days)) return '';
	return `${Math.floor(days / 365)}年前`;
}

const linksWithRss = FRIENDS_LINKS
	.map((link, i) => ({
		...link,
		_index: i,
		rssArticles: rssData[link.site_url.replace(/\/$/, '')] || [],
	}))
	.sort((a, b) => {
		const aDate = a.rssArticles[0]?.published_parsed || '';
		const bDate = b.rssArticles[0]?.published_parsed || '';
		return bDate.localeCompare(aDate) || a._index - b._index;
	});
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead 
			title={`友情链接 | ${SITE_TITLE}`} 
			description={`${SITE_DESCRIPTION} - 友情链接和博客聚合平台`}
		/>
		<style>
			main {
				width: 720px;
			}
			
			section {
				margin-bottom: 3rem;
			}
			
			section:last-child {
				margin-bottom: 0;
			}
			
			hgroup {
				margin-bottom: 2rem;
				padding: 2rem;
				background: var(--header-bg);
				border-radius: 12px;
				box-shadow: 0 2px 8px rgba(var(--black), 5%);
			}
			
			hgroup h2 {
				font-size: 1.75rem;
				margin-bottom: 0.75rem;
				color: var(--heading-color);
			}
			
			hgroup p {
				color: var(--footer-text);
				font-size: 1rem;
				line-height: 1.6;
			}
			
			.link-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 1.5rem;
			}
			
			.link-card {
				padding: 1.5rem;
				background: var(--header-bg);
				border-radius: 12px;
				box-shadow: 0 2px 8px rgba(var(--black), 5%);
				transition: all 0.3s ease;
				border: 1px solid transparent;
				overflow: hidden;
			}
			
			.link-card:hover {
				box-shadow: 0 4px 16px rgba(var(--black), 10%);
				transform: translateY(-2px);
				border-color: var(--border-color);
			}
			
			.link-card-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
				margin-bottom: 0.75rem;
			}
			
			.link-card-header a {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 1.1rem;
				font-weight: 600;
				color: var(--heading-color);
				text-decoration: none;
				transition: color 0.2s ease;
			}
			
			.link-card-header a:hover {
				color: var(--accent);
			}
			
			.link-card-header .external-icon {
				color: var(--footer-text);
				opacity: 0.7;
				transition: opacity 0.2s ease;
			}
			
			.link-card-header a:hover .external-icon {
				opacity: 1;
				color: var(--accent);
			}
			
			.link-inactive {
				display: inline-flex;
				align-items: center;
				padding: 0.25rem 0.75rem;
				background: rgba(var(--black), 5%);
				border-radius: 4px;
				font-size: 0.85rem;
				color: var(--footer-text);
				font-weight: 500;
			}
			
			.link-card p {
				color: var(--footer-text);
				font-size: 0.95rem;
				line-height: 1.6;
				margin: 0;
			}
			
			.rss-section {
				margin-top: 1rem;
				padding-top: 0.75rem;
				border-top: 1px solid var(--border-color);
			}
			
			.rss-header {
				display: flex;
				align-items: center;
				gap: 0.35rem;
				margin-bottom: 0.5rem;
				color: var(--footer-text);
				font-size: 0.8rem;
				font-weight: 500;
				opacity: 0.7;
			}
			
			.rss-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			
			.rss-item {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.5rem;
				padding: 0.2rem 0;
			}
			
			.rss-item + .rss-item {
				border-top: 1px solid rgba(var(--black), 3%);
			}
			
			.rss-link {
				color: var(--footer-text);
				font-size: 0.85rem;
				text-decoration: none;
				flex: 1;
				min-width: 0;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
				transition: color 0.2s ease;
			}
			
			.rss-link:hover {
				color: var(--accent);
				text-decoration: underline;
			}
			
			.rss-time {
				color: var(--footer-text);
				font-size: 0.75rem;
				opacity: 0.6;
				flex-shrink: 0;
			}
			
			.divider {
				margin: 3rem 0;
				border: none;
				height: 1px;
				background: linear-gradient(
					to right,
					transparent,
					var(--border-color),
					transparent
				);
			}
			
			@media (max-width: 720px) {
				hgroup {
					padding: 1.5rem;
				}
				
				hgroup h2 {
					font-size: 1.5rem;
				}
				
				.link-card {
					padding: 1.25rem;
				}
				
				.link-card-header a {
					font-size: 1rem;
				}
				
				.link-card p {
					font-size: 0.9rem;
				}
				
				.rss-link {
					font-size: 0.8rem;
				}
				
				.rss-time {
					font-size: 0.7rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<Breadcrumb items={[
				{ label: '首页', href: '/' },
				{ label: '链接', href: '/links' }
			]} />
			
			<section>
				<article>
					<hgroup>
						<h2>{FRIENDS_PAGE_TITLE}</h2>
						<p>{FRIENDS_PAGE_DESCRIPTION}</p>
					</hgroup>
					<ul class="link-list stagger-children">
						{linksWithRss.map(link => (
							<li class="link-card">
								<div class="link-card-header">
									<a href={link.site_url} target="_blank" rel="noopener noreferrer">
										{link.site_name}
										{link.is_active !== false ? (
											<svg class="external-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
												<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
												<polyline points="15 3 21 3 21 9" />
												<line x1="10" y1="14" x2="21" y2="3" />
											</svg>
										) : (
											<span class="link-inactive">链接失效</span>
										)}
									</a>
								</div>
								<p>{link.site_description}</p>
								{link.rssArticles.length > 0 && (
									<div class="rss-section">
										<div class="rss-header">
											<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20 5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93v-2.83Z"/></svg>
											<span>最近文章</span>
										</div>
										<ul class="rss-list">
											{link.rssArticles.slice(0, 5).map(item => (
												<li class="rss-item">
													<a href={item.link} target="_blank" rel="noopener noreferrer" class="rss-link">
														{item.title}
													</a>
													<span class="rss-time">{relativeTime(item.published_parsed)}</span>
												</li>
											))}
										</ul>
									</div>
								)}
							</li>
						))}
					</ul>
				</article>
			</section>
			
			<hr class="divider" />
			
			<section>
				<article>
					<hgroup>
						<h2>{BLOG_AGGREGATION_TITLE}</h2>
						<p>{BLOG_AGGREGATION_DESCRIPTION}</p>
					</hgroup>
					<ul class="link-list stagger-children">
						{BLOG_AGGREGATIONS.map(link => (
							<li class="link-card">
								<div class="link-card-header">
									<a href={link.site_url} target="_blank" rel="noopener noreferrer">
										{link.site_name}
										<svg class="external-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
											<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
											<polyline points="15 3 21 3 21 9" />
											<line x1="10" y1="14" x2="21" y2="3" />
										</svg>
									</a>
								</div>
								<p>{link.site_description}</p>
							</li>
						))}
					</ul>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>