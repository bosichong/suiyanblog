---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BackToTop from '../components/BackToTop.astro';
import { Icon } from 'astro-icon/components';
import { PROJECTS, PROJECTS_PAGE_TITLE, PROJECTS_PAGE_DESCRIPTION, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('blog');
const postMap = new Map(allPosts.map(p => [p.id, p.data]));

const pageTitle = PROJECTS_PAGE_TITLE;
const pageDescription = PROJECTS_PAGE_DESCRIPTION;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead 
			title={`${pageTitle} | ${SITE_TITLE}`} 
			description={`${SITE_DESCRIPTION} - ${pageDescription}`}
		/>
		<style>
			main {
				width: 720px;
			}

			section {
				margin-bottom: 3rem;
			}

			hgroup {
				margin-bottom: 2rem;
				padding: 2rem;
				background: var(--bg-soft);
				border-radius: 12px;
				box-shadow: 0 2px 8px rgba(var(--black), 5%);
			}

			hgroup h2 {
				font-size: 1.75rem;
				margin-bottom: 0.75rem;
				color: var(--heading-color);
			}

			hgroup p {
				color: var(--footer-text);
				font-size: 1rem;
				line-height: 1.6;
			}

			.project-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.project-card {
				position: relative;
				padding: 1.25rem;
				background: var(--bg-soft);
				border-radius: 12px;
				box-shadow: 0 2px 8px rgba(var(--black), 5%);
				transition: all 0.3s ease;
				border: 1px solid transparent;
				overflow: hidden;
			}

			@keyframes shimmer {
				from { transform: translateX(-100%); }
				to { transform: translateX(100%); }
			}

			.project-card::after {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				transform: translateX(-100%);
				background: linear-gradient(
					105deg,
					transparent 30%,
					rgba(255, 255, 255, 0.18) 45%,
					rgba(255, 255, 255, 0.3) 50%,
					rgba(255, 255, 255, 0.18) 55%,
					transparent 70%
				);
				pointer-events: none;
			}

			.project-card.hover::after,
			.project-card:hover::after {
				animation: shimmer 0.7s ease;
			}

			[data-theme="dark"] .project-card::after {
				background: linear-gradient(
					105deg,
					transparent 30%,
					rgba(255, 255, 255, 0.08) 45%,
					rgba(255, 255, 255, 0.14) 50%,
					rgba(255, 255, 255, 0.08) 55%,
					transparent 70%
				);
			}

			.project-card:hover {
				box-shadow: 0 4px 20px rgba(var(--black), 12%);
				transform: translateY(-2px);
				border-color: var(--border-color);
			}

			.project-header {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				margin-bottom: 0.5rem;
			}

			.project-name {
				font-size: 1.1rem;
				font-weight: 600;
				color: var(--heading-color);
			}

			.project-desc {
				color: var(--footer-text);
				font-size: 0.85rem;
				line-height: 1.5;
				margin: 0 0 0.75rem 0;
			}

			.project-meta {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 0.5rem;
			}

			.project-meta:last-child {
				margin-bottom: 0;
			}

			.meta-label {
				display: inline-flex;
				align-items: center;
				gap: 0.3rem;
				color: var(--text-muted);
				font-size: 0.78rem;
				flex-shrink: 0;
			}

			.meta-items {
				display: inline-flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.4rem;
			}

			.project-meta:has(.post-link) {
				flex-direction: column;
				align-items: flex-start;
				gap: 0.25rem;
			}

			.project-meta:has(.post-link) .meta-items {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: 0.25rem;
			}

			.repo-link {
				display: inline-flex;
				align-items: center;
				gap: 0.2rem;
				padding: 0.15rem 0.5rem;
				background: rgba(var(--black), 5%);
				border-radius: 4px;
				font-size: 0.78rem;
				color: var(--text-color);
				text-decoration: none;
				transition: all 0.2s ease;
			}

			.repo-link:hover {
				background: var(--accent);
				color: var(--accent-text);
			}

			.demo-link {
				display: inline-flex;
				align-items: center;
				gap: 0.2rem;
				padding: 0.15rem 0.5rem;
				background: rgba(var(--black), 5%);
				border-radius: 4px;
				font-size: 0.78rem;
				color: var(--text-color);
				text-decoration: none;
				transition: all 0.2s ease;
			}

			.demo-link:hover {
				background: var(--accent);
				color: var(--accent-text);
			}

			.tech-tag {
				display: inline-flex;
				align-items: center;
				padding: 0.15rem 0.5rem;
				background: rgba(var(--black), 5%);
				border-radius: 4px;
				font-size: 0.75rem;
				color: var(--text-muted);
				transition: all 0.2s ease;
			}

			.project-card:hover .tech-tag {
				color: var(--text-color);
			}

			.post-link {
				display: flex;
				align-items: center;
				gap: 0.2rem;
				font-size: 0.8rem;
				color: var(--text-color);
				text-decoration: none;
				transition: color 0.2s ease;
			}

			.post-link:hover {
				color: var(--accent);
			}

			@media (max-width: 720px) {
				hgroup {
					padding: 1.5rem;
				}

				hgroup h2 {
					font-size: 1.5rem;
				}

				.project-card {
					padding: 1rem;
				}

				.project-name {
					font-size: 1rem;
				}

				.project-desc {
					font-size: 0.8rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<section>
				<article>
					<hgroup>
						<h2>{pageTitle}</h2>
						<p>{pageDescription}</p>
					</hgroup>
					<ul class="project-list">
						{PROJECTS.map(project => (
							<li class="project-card">
								<div class="project-header">
									<Icon name="mdi:folder-open" width={20} height={20} aria-hidden="true" />
									<span class="project-name">{project.name}</span>
								</div>
								<p class="project-desc">{project.description}</p>

								<div class="project-meta">
									<span class="meta-label">
										<Icon name="mdi:source-repository" width={14} height={14} aria-hidden="true" />
										仓库
									</span>
									<span class="meta-items">
										{project.repoUrls.map(repo => (
											<a href={repo.url} target="_blank" rel="noopener noreferrer" class="repo-link">
												<Icon name={repo.label === 'GitHub' ? 'mdi:github' : 'mdi:source-repository'} width={13} height={13} aria-hidden="true" />
												{repo.label}
											</a>
										))}
									</span>
								</div>

								{project.demoUrl && (
									<div class="project-meta">
										<span class="meta-label">
											<Icon name="mdi:rocket" width={14} height={14} aria-hidden="true" />
											演示
										</span>
										<span class="meta-items">
											<a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="demo-link">
												<Icon name="mdi:open-in-new" width={13} height={13} aria-hidden="true" />
												{project.demoUrl}
											</a>
										</span>
									</div>
								)}

								{project.techStack && project.techStack.length > 0 && (
									<div class="project-meta">
										<span class="meta-label">
											<Icon name="mdi:code-tags" width={14} height={14} aria-hidden="true" />
											技术栈
										</span>
										<span class="meta-items">
											{project.techStack.map(tech => (
												<span class="tech-tag">{tech}</span>
											))}
										</span>
									</div>
								)}

								{project.relatedPosts && project.relatedPosts.length > 0 && (
									<div class="project-meta">
										<span class="meta-label">
											<Icon name="mdi:file-document-outline" width={14} height={14} aria-hidden="true" />
											相关文章
										</span>
										<span class="meta-items">
											{project.relatedPosts.map(slug => {
												const post = postMap.get(slug);
												return post ? (
													<a href={`/blog/${slug}`} class="post-link">
														<Icon name="mdi:file-document-outline" width={13} height={13} aria-hidden="true" />
														{post.title}
													</a>
												) : null;
											})}
										</span>
									</div>
								)}
							</li>
						))}
					</ul>
				</article>
			</section>
		</main>
		<Footer />
		<BackToTop />

		<script>
			const list = document.querySelector('.project-list');
			if (list) {
				let currentCard = /** @type {Element | null} */ (null);
				list.addEventListener('mouseover', (e) => {
					const card = e.target instanceof Element ? e.target.closest('.project-card') : null;
					if (card && card !== currentCard) {
						if (currentCard) currentCard.classList.remove('hover');
						currentCard = card;
						currentCard.classList.add('hover');
					}
				});
				list.addEventListener('mouseout', (e) => {
					const card = e.target instanceof Element ? e.target.closest('.project-card') : null;
					if (card && e instanceof MouseEvent && e.relatedTarget instanceof Node && !card.contains(e.relatedTarget)) {
						card.classList.remove('hover');
						if (currentCard === card) currentCard = null;
					}
				});
			}
			window.addEventListener('pageshow', (e) => {
				if (e.persisted) {
					document.querySelectorAll('.project-card.hover').forEach(c => c.classList.remove('hover'));
				}
			});
		</script>
	</body>
</html>