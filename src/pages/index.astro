---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BackToTop from '../components/BackToTop.astro';
import { SITE_DESCRIPTION, SITE_AUTHOR, SITE_TITLE, HOME_POSTS_COUNT } from '../consts';
import { formatDateShort } from '../utils/date';

// 获取所有博客文章，按时间排序，取最新 N 篇
const recentPosts = (await getCollection('blog'))
	.sort((a, b) => new Date(b.data.time).valueOf() - new Date(a.data.time).valueOf())
	.slice(0, HOME_POSTS_COUNT);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`首页 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
			}

			.hero {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto 3rem;
				padding-top: 2rem;
				display: flex;
				align-items: center;
				gap: 1rem;
			}
			.hero-avatar {
				width: 4rem;
				height: 4rem;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.hero-text {
				flex: 1;
			}
			.hero-title {
				font-size: 1.5rem;
				font-weight: 500;
				line-height: 1.25;
				margin: 0;
				color: var(--text);
				text-align: left;
				text-indent: 0;
			}
			.hero-desc {
				font-size: 0.875rem;
				line-height: 1.25;
				margin: 0.25rem 0 0;
				color: var(--text-soft);
				text-align: left;
				text-indent: 0;
			}
			@media (min-width: 721px) {
				.hero {
					margin-bottom: 4rem;
				}
				.hero-avatar {
					width: 5rem;
					height: 5rem;
				}
				.hero-title {
					font-size: 1.875rem;
				}
			}

			.category-section {
				margin-bottom: 3rem;
			}

			.view-more {
				display: block;
				margin-top: 1rem;
				text-align: center;
				color: var(--accent);
				text-decoration: none;
				font-size: 0.95rem;
				transition: color 0.2s ease;
			}

			.view-more:hover {
				color: var(--accent-dark);
			}

			.post-item {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				text-decoration: none;
				color: var(--text-color);
				padding: 0.6rem 0;
			}
			.post-line {
				flex: 1;
				height: 1px;
				background: var(--border-color);
				transition: background 0.2s ease;
			}
			.post-item:hover .post-line {
				background: var(--text);
			}
			.post-title {
				font-size: 1.125rem;
				line-height: 1.5;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
				flex-shrink: 1;
				min-width: 0;
			}
			.post-date {
				color: var(--text-muted);
				font-size: 0.9rem;
				font-weight: 500;
				white-space: nowrap;
				flex-shrink: 0;
				transition: color 0.2s ease;
			}
			.post-item:hover .post-date {
				color: var(--text);
			}

			@media (max-width: 720px) {
				.post-title {
					font-size: 1rem;
				}
				.post-date {
					font-size: 0.85rem;
				}
			}

			/* 动态加载动画：仅在非 bfcache 恢复时播放 */
			body:not(.bfcache) .animate-header {
				animation: suiyan-fade-up 500ms cubic-bezier(0.16, 1, 0.3, 1) 0ms both;
			}
			body:not(.bfcache) .animate-avatar {
				animation: suiyan-scale-in 600ms cubic-bezier(0.16, 1, 0.3, 1) 200ms both;
			}
			body:not(.bfcache) .animate-hero-text {
				animation: suiyan-fade-up 500ms cubic-bezier(0.16, 1, 0.3, 1) 400ms both;
			}
			body:not(.bfcache) .animate-posts {
				animation: suiyan-fade-up 500ms cubic-bezier(0.16, 1, 0.3, 1) 600ms both;
			}
			body:not(.bfcache) .animate-footer {
				animation: suiyan-fade-up 500ms cubic-bezier(0.16, 1, 0.3, 1) 800ms both;
			}

			/* 文章列表逐条动画 */
			body:not(.bfcache) .post-item {
				animation: suiyan-fade-up 400ms cubic-bezier(0.16, 1, 0.3, 1) both;
			}
			body:not(.bfcache) .post-item:nth-child(1) { animation-delay: 700ms; }
			body:not(.bfcache) .post-item:nth-child(2) { animation-delay: 750ms; }
			body:not(.bfcache) .post-item:nth-child(3) { animation-delay: 800ms; }
			body:not(.bfcache) .post-item:nth-child(4) { animation-delay: 850ms; }
			body:not(.bfcache) .post-item:nth-child(5) { animation-delay: 900ms; }
			body:not(.bfcache) .post-item:nth-child(6) { animation-delay: 950ms; }
			body:not(.bfcache) .post-item:nth-child(7) { animation-delay: 1000ms; }
			body:not(.bfcache) .post-item:nth-child(8) { animation-delay: 1050ms; }
			body:not(.bfcache) .post-item:nth-child(9) { animation-delay: 1100ms; }
			body:not(.bfcache) .post-item:nth-child(10) { animation-delay: 1150ms; }
			body:not(.bfcache) .post-item:nth-child(n + 11) { animation-delay: 1200ms; }

			body:not(.bfcache) .view-more {
				animation: suiyan-fade-up 400ms cubic-bezier(0.16, 1, 0.3, 1) 1300ms both;
			}
		</style>
	</head>
	<body>
		<script is:inline>
			(function () {
				var bc = performance.getEntriesByType('navigation')[0]?.type === 'back_forward';
				if (bc) document.body.classList.add('bfcache');
			})();
		</script>
		<div class="animate-header">
			<Header />
		</div>
		<main id="main">
			<header class="hero">
				<a href="/">
					<img src="/assets/images/avatar.jpg" alt={SITE_AUTHOR} class="hero-avatar animate-avatar" loading="eager" fetchpriority="high" decoding="async" width="80" height="80" />
				</a>
				<div class="hero-text animate-hero-text">
					<p class="hero-title">{SITE_TITLE}</p>
					<p class="hero-desc">{SITE_DESCRIPTION}</p>
				</div>
			</header>
			<section class="category-section animate-posts">
				{recentPosts.map((post) => (
					<a href={`/blog/${post.id}`} class="post-item" transition:name={`post-title-${post.id}`}>
						<span class="post-title">{post.data.title}</span>
						<div class="post-line"></div>
						<time class="post-date" datetime={post.data.time}>
							{formatDateShort(post.data.time)}
						</time>
					</a>
				))}
				<a href="/archive" class="view-more">更多文章...</a>
			</section>
		</main>
		<div class="animate-footer">
			<Footer />
		</div>
		<BackToTop />
	</body>
</html>