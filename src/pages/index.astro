---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { formatDateShort } from '../utils/date';

// 获取所有博客文章
const allPosts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.time).valueOf() - new Date(a.data.time).valueOf(),
);

// 按标签分类文章（取前10篇）
const dailyPosts = allPosts
	.filter(post => post.data.tags.includes('daily'))
	.slice(0, 10);

const technologyPosts = allPosts
	.filter(post => post.data.tags.includes('technology'))
	.slice(0, 10);



// 获取每个标签下最新文章的发布时间
const getLatestTime = (posts) => posts.length > 0 ? new Date(posts[0].data.time).valueOf() : 0;

// 按最新文章时间排序（最新更新的标签排最前）
const tagSections = [
	{ name: '日常', posts: dailyPosts, tag: 'daily', latestTime: getLatestTime(dailyPosts) },
	{ name: '技术', posts: technologyPosts, tag: 'technology', latestTime: getLatestTime(technologyPosts) },

].filter(section => section.posts.length > 0)
  .sort((a, b) => b.latestTime - a.latestTime);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`首页 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
			}
			
			.category-section {
				margin-bottom: 3rem;
			}
			
			.category-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1.5rem;
				padding: 1rem 0;
			}
			
			.category-header h3 {
				font-size: 1.5rem;
				margin: 0;
				color: var(--heading-color);
			}
			
			.view-more {
				color: var(--accent);
				text-decoration: none;
				font-size: 0.95rem;
				transition: color 0.2s ease;
			}
			
			.view-more:hover {
				color: var(--accent-dark);
			}
			
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			
			.post-list-grid {
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 1rem;
				padding: 0.75rem 1.5rem;
				align-items: center;
				transition: background-color 0.2s ease;
				border-bottom: 1px solid var(--border-color);
			}
			
			.post-list-grid:last-child {
				border-bottom: none;
			}
			
			.post-list-grid:hover {
				background-color: rgba(var(--gray), 5%);
			}
			
			.post-list-grid a {
				text-decoration: none;
				color: var(--text-color);
				font-size: 1.125rem;
				transition: color 0.2s ease;
				line-height: 1.5;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			
			.post-list-grid a:hover {
				color: var(--accent);
			}
			
			.post-list-grid time {
				color: var(--footer-text);
				font-size: 0.9rem;
				font-weight: 500;
				white-space: nowrap;
			}
			
			@media (max-width: 720px) {
				.post-list-grid {
					padding: 0.75rem 1rem;
				}
				
				.post-list-grid a {
					font-size: 1rem;
				}
				
				.post-list-grid time {
					font-size: 0.85rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			{tagSections.map((section) => (
				<section class="category-section">
					<div class="category-header">
						<h3>{section.name}</h3>
						<a href={`/tags/${section.tag}`} class="view-more">浏览更多</a>
					</div>
					<ul class="post-list">
						{section.posts.map((post) => (
							<li class="post-list-grid">
								<a href={`/blog/${post.id}`}>
									{post.data.title}
								</a>
								<time dateTime={post.data.time}>
									{formatDateShort(post.data.time)}
								</time>
							</li>
						))}
					</ul>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>