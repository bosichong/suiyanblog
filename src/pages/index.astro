---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_AUTHOR, SITE_TITLE } from '../consts';
import { formatDateShort } from '../utils/date';

// 获取所有博客文章
const allPosts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.time).valueOf() - new Date(a.data.time).valueOf(),
);

// 按标签分类文章（取前10篇）
const dailyPosts = allPosts
	.filter(post => post.data.tags.includes('daily'))
	.slice(0, 10);

const technologyPosts = allPosts
	.filter(post => post.data.tags.includes('technology'))
	.slice(0, 10);



// 获取每个标签下最新文章的发布时间
const getLatestTime = (posts) => posts.length > 0 ? new Date(posts[0].data.time).valueOf() : 0;

// 按最新文章时间排序（最新更新的标签排最前）
const tagSections = [
	{ name: '日常', posts: dailyPosts, tag: 'daily', latestTime: getLatestTime(dailyPosts), moreText: '更多日常...' },
	{ name: '技术', posts: technologyPosts, tag: 'technology', latestTime: getLatestTime(technologyPosts), moreText: '更多技术...' },

].filter(section => section.posts.length > 0)
  .sort((a, b) => b.latestTime - a.latestTime);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`首页 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
			}
			
			.hero {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto 3rem;
				display: flex;
				align-items: center;
				gap: 1rem;
			}
			.hero-avatar {
				width: 4rem;
				height: 4rem;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.hero-text {
				flex: 1;
			}
			.hero-title {
				font-size: 1.5rem;
				font-weight: 500;
				line-height: 1.25;
				margin: 0;
				color: var(--text);
				text-align: left;
				text-indent: 0;
			}
			.hero-desc {
				font-size: 0.875rem;
				line-height: 1.25;
				margin: 0.25rem 0 0;
				color: var(--text-soft);
				text-align: left;
				text-indent: 0;
			}
			@media (min-width: 721px) {
				.hero {
					margin-bottom: 4rem;
				}
				.hero-avatar {
					width: 5rem;
					height: 5rem;
				}
				.hero-title {
					font-size: 1.875rem;
				}
			}
			
			.category-section {
				margin-bottom: 3rem;
			}
			
			.view-more {
				display: block;
				margin-top: 1rem;
				text-align: right;
				color: var(--accent);
				text-decoration: none;
				font-size: 0.95rem;
				transition: color 0.2s ease;
			}
			
			.view-more:hover {
				color: var(--accent-dark);
			}
			
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			
			.post-list-grid {
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 1rem;
				padding: 0.75rem 1.5rem;
				align-items: center;
				transition: background-color 0.2s ease;
				border-bottom: 1px solid var(--border-color);
			}
			
			.post-list-grid:last-child {
				border-bottom: none;
			}
			
			.post-list-grid:hover {
				background-color: rgba(var(--gray), 5%);
			}
			
			.post-list-grid a {
				text-decoration: none;
				color: var(--text-color);
				font-size: 1.125rem;
				transition: color 0.2s ease;
				line-height: 1.5;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			
			.post-list-grid a:hover {
				color: var(--accent);
			}
			
			.post-list-grid time {
				color: var(--footer-text);
				font-size: 0.9rem;
				font-weight: 500;
				white-space: nowrap;
			}
			
			@media (max-width: 720px) {
				.post-list-grid {
					padding: 0.75rem 1rem;
				}
				
				.post-list-grid a {
					font-size: 1rem;
				}
				
				.post-list-grid time {
					font-size: 0.85rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<header class="hero">
				<a href="/">
					<img src="/assets/images/avatar.jpg" alt={SITE_AUTHOR} class="hero-avatar" loading="eager" fetchpriority="high" decoding="async" width="80" height="80" />
				</a>
				<div class="hero-text">
					<p class="hero-title">{SITE_TITLE}</p>
					<p class="hero-desc">{SITE_DESCRIPTION}</p>
				</div>
			</header>
			{tagSections.map((section) => (
				<section class="category-section">
					<ul class="post-list stagger-children">
						{section.posts.map((post) => (
							<li class="post-list-grid">
								<a href={`/blog/${post.id}`} transition:name={`post-title-${post.id}`}>
									{post.data.title}
								</a>
								<time datetime={post.data.time}>
									{formatDateShort(post.data.time)}
								</time>
							</li>
						))}
					</ul>
					<a href={`/tags/${section.tag}`} class="view-more">{section.moreText}</a>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>