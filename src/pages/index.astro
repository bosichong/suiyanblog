---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagList from '../components/TagList.astro';
import { Icon } from 'astro-icon/components';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// 获取所有博客文章
const allPosts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.time).valueOf() - new Date(a.data.time).valueOf(),
);

// 按标签分类文章（取前10篇）
const dailyPosts = allPosts
	.filter(post => post.data.tags.includes('daily'))
	.slice(0, 10);

const technologyPosts = allPosts
	.filter(post => post.data.tags.includes('technology'))
	.slice(0, 10);

const journalPosts = allPosts
	.filter(post => post.data.tags.includes('journal'))
	.slice(0, 10);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`首页 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
			}
			.category-section {
				margin-bottom: 3rem;
			}
			.category-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1.5rem;
				padding: 1rem 0;
			}
			.category-header h3 {
				font-size: 1.5rem;
				margin: 0;
				color: var(--heading-color);
			}
			.view-more {
				color: var(--accent);
				text-decoration: none;
				font-size: 0.95rem;
				transition: color 0.2s ease;
			}
			.view-more:hover {
				color: var(--accent-dark);
			}
			.post-list {
				display: flex;
				flex-direction: column;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.post-list li {
				width: 100%;
				background: var(--header-bg);
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 2px 12px rgba(var(--black), 8%);
				transition: all 0.3s ease;
			}
			.post-list li:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 25px rgba(var(--black), 15%);
			}
			.post-list li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			.post-list li img {
				margin-bottom: 0;
				border-radius: 0;
				width: 100%;
				height: auto;
				display: block;
			}
			.post-list li a {
				display: block;
				color: inherit;
			}
			.post-content {
				padding: 2rem;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				margin-bottom: 1rem;
				font-size: 1rem;
				color: var(--footer-text);
				font-weight: 500;
			}
			.meta-item {
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.meta-item svg {
				color: var(--accent);
				flex-shrink: 0;
			}
			.title {
				margin: 0;
				color: var(--heading-color);
				line-height: 1.3;
				font-size: 1.875rem;
				font-weight: 700;
				margin-bottom: 1rem;
			}
			.description {
				margin: 0;
				color: var(--text-color);
				line-height: 1.6;
				font-size: 1.125rem;
				opacity: 0.9;
			}
			.post-list li a:hover .title {
				color: var(--accent);
			}
			.post-list li a:hover .description {
				opacity: 1;
			}
			.post-list a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				.post-list {
					gap: 1.5rem;
				}
				.post-content {
					padding: 1.5rem;
				}
				.title {
					font-size: 1.5rem;
					margin-bottom: 0.75rem;
				}
				.description {
					font-size: 1rem;
				}
				.post-meta {
					font-size: 0.9rem;
					margin-bottom: 0.75rem;
					gap: 1rem;
				}
				.meta-item {
					gap: 0.375rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<!-- 日常分类 -->
			{dailyPosts.length > 0 && (
				<section class="category-section">
					<div class="category-header">
						<h3>日常</h3>
						<a href="/tags/daily" class="view-more">浏览更多</a>
					</div>
					<ul class="post-list">
						{dailyPosts.map((post, idx) => (
							<li>
								<a href={`/blog/${post.id}`} aria-label={post.data.title}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt={post.data.heroImageAlt || ''} 
											loading={idx === 0 ? 'eager' : 'lazy'} />
									)}
									<div class="post-content">
										<div class="post-meta">
											<div class="meta-item">
												<Icon name="mdi:calendar" width={16} height={16} aria-hidden="true" />
												<FormattedDate date={post.data.time} />
											</div>
											<div class="meta-item">
												<Icon name="mdi:account" width={16} height={16} aria-hidden="true" />
												<span class="author">{SITE_AUTHOR}</span>
											</div>
										</div>
										<hr aria-hidden="true" />
										<h2 class="title">{post.data.title}</h2>
										{post.data.description && (
											<p class="description">{post.data.description}</p>
										)}
										<TagList tags={post.data.tags} limit={3} />
									</div>
								</a>
							</li>
						))}
					</ul>
				</section>
			)}

			<!-- 技术分类 -->
			{technologyPosts.length > 0 && (
				<section class="category-section">
					<div class="category-header">
						<h3>技术</h3>
						<a href="/tags/technology" class="view-more">浏览更多</a>
					</div>
					<ul class="post-list">
						{technologyPosts.map((post, idx) => (
							<li>
								<a href={`/blog/${post.id}`} aria-label={post.data.title}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt={post.data.heroImageAlt || ''} 
											loading="lazy" />
									)}
									<div class="post-content">
										<div class="post-meta">
											<div class="meta-item">
												<Icon name="mdi:calendar" width={16} height={16} aria-hidden="true" />
												<FormattedDate date={post.data.time} />
											</div>
											<div class="meta-item">
												<Icon name="mdi:account" width={16} height={16} aria-hidden="true" />
												<span class="author">{SITE_AUTHOR}</span>
											</div>
										</div>
										<hr aria-hidden="true" />
										<h2 class="title">{post.data.title}</h2>
										{post.data.description && (
											<p class="description">{post.data.description}</p>
										)}
										<TagList tags={post.data.tags} limit={3} />
									</div>
								</a>
							</li>
						))}
					</ul>
				</section>
			)}

			<!-- 期刊分类 -->
			{journalPosts.length > 0 && (
				<section class="category-section">
					<div class="category-header">
						<h3>期刊</h3>
						<a href="/tags/journal" class="view-more">浏览更多</a>
					</div>
					<ul class="post-list">
						{journalPosts.map((post, idx) => (
							<li>
								<a href={`/blog/${post.id}`} aria-label={post.data.title}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt={post.data.heroImageAlt || ''} 
											loading="lazy" />
									)}
									<div class="post-content">
										<div class="post-meta">
											<div class="meta-item">
												<Icon name="mdi:calendar" width={16} height={16} aria-hidden="true" />
												<FormattedDate date={post.data.time} />
											</div>
											<div class="meta-item">
												<Icon name="mdi:account" width={16} height={16} aria-hidden="true" />
												<span class="author">{SITE_AUTHOR}</span>
											</div>
										</div>
										<hr aria-hidden="true" />
										<h2 class="title">{post.data.title}</h2>
										{post.data.description && (
											<p class="description">{post.data.description}</p>
										)}
										<TagList tags={post.data.tags} limit={3} />
									</div>
								</a>
							</li>
						))}
					</ul>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>