---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BackToTop from '../components/BackToTop.astro';
import { SITE_DESCRIPTION, SITE_AUTHOR, SITE_TITLE, HOME_POSTS_COUNT } from '../consts';
import { formatDateShort } from '../utils/date';

// 获取所有博客文章，按时间排序，取最新 N 篇
const recentPosts = (await getCollection('blog'))
	.sort((a, b) => new Date(b.data.time).valueOf() - new Date(a.data.time).valueOf())
	.slice(0, HOME_POSTS_COUNT);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`首页 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
			}

			.hero {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto 3rem;
				padding-top: 2rem;
				display: flex;
				align-items: center;
				gap: 1rem;
			}
			.hero-avatar {
				width: 4rem;
				height: 4rem;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.hero-text {
				flex: 1;
			}
			.hero-title {
				font-size: 1.5rem;
				font-weight: 500;
				line-height: 1.25;
				margin: 0;
				color: var(--text);
				text-align: left;
				text-indent: 0;
			}
			.hero-desc {
				font-size: 0.875rem;
				line-height: 1.25;
				margin: 0.25rem 0 0;
				color: var(--text-soft);
				text-align: left;
				text-indent: 0;
			}
			@media (min-width: 721px) {
				.hero {
					margin-bottom: 4rem;
				}
				.hero-avatar {
					width: 5rem;
					height: 5rem;
				}
				.hero-title {
					font-size: 1.875rem;
				}
			}

			.category-section {
				margin-bottom: 3rem;
			}

			.view-more {
				display: block;
				margin-top: 1rem;
				text-align: center;
				color: var(--accent);
				text-decoration: none;
				font-size: 0.95rem;
				transition: color 0.2s ease;
			}

			.view-more:hover {
				color: var(--accent-dark);
			}

			.post-item {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				text-decoration: none;
				color: var(--text-color);
				padding: 0.6rem 0;
			}
			.post-line {
				flex: 1;
				height: 1px;
				background: var(--border-color);
				transition: background 1s ease;
			}
			@keyframes lineWipe {
				0% { transform: scaleX(1); }
				25% { transform: scaleX(0); }
				50% { transform: scaleX(0); }
				100% { transform: scaleX(1); }
			}
			.post-line.line-anim {
				animation: lineWipe 0.7s ease-in-out forwards;
				transform-origin: left;
				background: var(--text);
			}
			.post-title {
				font-size: 1.125rem;
				line-height: 1.5;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
				flex-shrink: 1;
				min-width: 0;
			}
			.post-date {
				color: var(--text-muted);
				font-size: 0.9rem;
				font-weight: 500;
				white-space: nowrap;
				flex-shrink: 0;
				transition: color 0.2s ease;
			}
			.post-item:hover .post-date {
				color: var(--text);
			}

			@media (max-width: 720px) {
				.post-title {
					font-size: 1rem;
				}
				.post-date {
					font-size: 0.85rem;
				}
			}

		</style>
	</head>
	<body>
		<Header />
		<main id="main">
			<header class="hero">
				<a href="/">
					<img src="/assets/images/avatar.jpg" alt={SITE_AUTHOR} class="hero-avatar" loading="eager" fetchpriority="high" decoding="async" width="80" height="80" />
				</a>
				<div class="hero-text">
					<p class="hero-title">{SITE_TITLE}</p>
					<p class="hero-desc">{SITE_DESCRIPTION}</p>
				</div>
			</header>
			<section class="category-section">
				{recentPosts.map((post) => (
					<a href={`/blog/${post.id}`} class="post-item" transition:name={`post-title-${post.id}`}>
						<span class="post-title">{post.data.title}</span>
						<div class="post-line"></div>
						<time class="post-date" datetime={post.data.time}>
							{formatDateShort(post.data.time)}
						</time>
					</a>
				))}
				<a href="/archive" class="view-more">更多文章...</a>
			</section>
		</main>
		<Footer />
		<BackToTop />
		<script>
			document.addEventListener('mouseover', (e) => {
				const item = e.target.closest('.category-section .post-item');
				if (!item) return;
				const line = item.querySelector('.post-line');
				if (!line || line.dataset.animating === '1') return;
				line.dataset.animating = '1';
				line.classList.add('line-anim');
			});
			document.addEventListener('mouseout', (e) => {
				const item = e.target.closest('.category-section .post-item');
				if (!item) return;
				const related = e.relatedTarget;
				if (related && item.contains(related)) return;
				const line = item.querySelector('.post-line');
				if (line) delete line.dataset.animating;
			});
			document.addEventListener('animationend', (e) => {
				if (e.animationName === 'lineWipe') {
					e.target.classList.remove('line-anim');
				}
			});
		</script>
	</body>
</html>