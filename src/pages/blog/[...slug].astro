---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// 获取所有文章并按日期排序
const allPosts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.time).valueOf() - new Date(a.data.time).valueOf(),
);

// 找到当前文章的位置
const currentIndex = allPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const nextPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;

// 计算相关文章（有相同标签的文章）
const currentTags = post.data.tags || [];
const relatedPosts = allPosts
	.filter(p => {
		if (p.id === post.id) return false;
		const pTags = p.data.tags || [];
		return currentTags.some(tag => pTags.includes(tag));
	})
	.slice(0, 5);
---

<BlogPost {...post.data} postId={post.id} prevPost={prevPost} nextPost={nextPost} relatedPosts={relatedPosts}>
	<Content />
</BlogPost>
