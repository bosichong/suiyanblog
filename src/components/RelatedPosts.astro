---
import { formatDateFull } from '../utils/date';

interface Props {
	title?: string;
	posts: Array<{
		id: string;
		data: {
			title: string;
			time: string;
		};
	}>;
}

const { title = '相关文章', posts } = Astro.props;

if (!posts || posts.length === 0) {
	return;
}
---

<section class="related-posts">
	<h2>{title}</h2>
	<ul class="stagger-children">
		{posts.slice(0, 5).map((post) => (
			<li>
				<a href={`/blog/${post.id}`}>
					<span class="post-title">{post.data.title}</span>
					<time>{formatDateFull(post.data.time)}</time>
				</a>
			</li>
		))}
	</ul>
</section>

<style>
	.related-posts {
		margin: 2rem 0;
		padding: 1.5rem;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 12px;
	}

	.related-posts h2 {
		margin: 0 0 1rem 0;
		font-size: 1.25rem;
		color: rgb(var(--black));
	}

	.related-posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.related-posts li {
		margin-bottom: 0.5rem;
	}

	.related-posts li:last-child {
		margin-bottom: 0;
	}

	.related-posts a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 0.625rem 0.875rem;
		border-radius: 8px;
		text-decoration: none;
		color: var(--text-color);
		transition: all 0.2s ease;
	}

	.related-posts a:hover {
		background: var(--bg-soft);
		color: var(--accent-dark);
	}

	.post-title {
		flex: 1;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 70%;
		text-decoration: none;
	}

	.related-posts time {
		flex-shrink: 0;
		font-size: 0.85rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 480px) {
		.related-posts a {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.25rem;
		}
	}
</style>