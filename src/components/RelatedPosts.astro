---
import { formatDateFull } from '../utils/date';

interface Props {
	title?: string;
	posts: Array<{
		id: string;
		data: {
			title: string;
			time: string;
		};
	}>;
}

const { title = '相关文章', posts } = Astro.props;

if (!posts || posts.length === 0) {
	return;
}
---

<section class="related-posts">
	<h2>{title}</h2>
	{
		posts.slice(0, 5).map((post) => (
			<a href={`/blog/${post.id}`} class="post-item">
				<span class="post-title">{post.data.title}</span>
				<div class="post-line"></div>
				<time class="post-date">{formatDateFull(post.data.time)}</time>
			</a>
		))
	}
</section>

<style>
	.related-posts {
		margin: 2rem 0;
		padding: 1.5rem 0;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 12px;
	}

	.related-posts h2 {
		margin: 0 0 1rem 0;
		padding: 0 1.5rem;
		font-size: 1.25rem;
		color: var(--text);
	}

	.post-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 1.5rem;
		text-decoration: none;
		color: var(--text-color);
	}
	.post-line {
		flex: 1;
		height: 1px;
		background: var(--border-color);
		transition: background 0.2s ease;
	}
	.post-item:hover .post-line {
		background: var(--text);
	}
	.post-title {
		font-size: 1.125rem;
		line-height: 1.5;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		flex-shrink: 1;
		min-width: 0;
	}
	.post-date {
		color: var(--text-muted);
		font-size: 0.9rem;
		font-weight: 500;
		white-space: nowrap;
		flex-shrink: 0;
		transition: color 0.2s ease;
	}
	.post-item:hover .post-date {
		color: var(--text);
	}
</style>