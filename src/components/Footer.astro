---
import { Icon } from 'astro-icon/components';
import { SITE_TITLE_EN, SNS_LINKS } from '../consts';
import BackToTop from './BackToTop.astro';
const today = new Date();
---

<footer>
	<div class="footer-content">
		<p class="copyright">
			&copy; 2017-{today.getFullYear()} {SITE_TITLE_EN}
		</p>
		<div class="social-links">
			{SNS_LINKS.map(link => (
				<a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={link.name}>
					<Icon name={link.icon} width={24} height={24} aria-hidden="true" />
				</a>
			))}
		</div>
		<p class="license">
			<a href="https://creativecommons.org/licenses/by-nc-sa/4.0/?ref=chooser-v1" target="_blank" rel="license noopener noreferrer">
				CC BY-NC-SA 4.0
			</a>
		</p>
	</div>
	<BackToTop />
	<script data-goatcounter="https://suiyan.goatcounter.com/count"
        async src="https://gc.zgo.at/count.js"></script>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-content {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}
	.copyright {
		margin: 0;
	}
	.social-links {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.75em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
		transition: color 0.2s ease;
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
	.license {
		margin: 0;
	}
	.license a {
		text-decoration: none;
		color: rgb(var(--gray));
		font-size: 0.9em;
		transition: color 0.2s ease;
	}
	.license a:hover {
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 600px) {
		.footer-content {
			flex-direction: column;
			gap: 1rem;
		}
	}
</style>
