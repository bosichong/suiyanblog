---
import { slugify } from '../utils/slugify';

interface Props {
	tags: string[];
	showLabel?: boolean;
	limit?: number;
}

const { tags, showLabel = false, limit } = Astro.props;
const displayTags = limit ? tags.slice(0, limit) : tags;
const hasMoreTags = limit && tags.length > limit;
---

<div class="tag-list">
	{showLabel && <span class="tag-label">Tags:</span>}
	<ul class="tags">
		{displayTags.map((tag) => (
			<li class="tag">
				<a href={`/tags/${slugify(tag)}`} class="tag-link">
					{tag}
				</a>
			</li>
		))}
		{hasMoreTags && (
			<li class="tag-more">
				+{tags.length - limit!} more
			</li>
		)}
	</ul>
</div>

<style>
	.tag-list {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin: 0.5rem 0;
	}

	.tag-label {
		font-size: 0.875rem;
		font-weight: 600;
		color: rgb(var(--gray));
		margin-right: 0.25rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.tag {
		margin: 0;
	}

	.tag-link {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		background: transparent;
		color: var(--text-soft);
		text-decoration: none;
		border-radius: 9999px;
		font-size: 0.875rem;
		font-weight: 500;
		border: 1px solid var(--border);
	}

	.tag-link:hover {
		background: var(--bg-soft);
		border-color: var(--accent);
		color: var(--accent-dark);
	}

	.tag-link:focus {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.tag-more {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		background: var(--bg-soft);
		color: var(--text-muted);
		border-radius: 9999px;
		font-size: 0.875rem;
		font-style: italic;
	}

	/* Responsive adjustments */
	@media (max-width: 720px) {
		.tag-list {
			gap: 0.375rem;
		}
		
		.tags {
			gap: 0.375rem;
		}
		
		.tag-link {
			padding: 0.2rem 0.6rem;
			font-size: 0.8rem;
		}
	}
</style>