---
import { MENU_ITEMS } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import { Icon } from 'astro-icon/components';
---

<header>
	<a href="#main" class="skip-link">Skip to main content</a>
	<nav>
		<div class="nav-inner">
			<div class="nav-left">
				<ThemeToggle />
				<a href="/search" class="search-link" aria-label="搜索" title="搜索">
					<Icon name="mdi:magnify" width={18} height={18} aria-hidden="true" />
				</a>
			</div>
			<div class="internal-links" id="nav-menu">
				{MENU_ITEMS.map(item => (
					<HeaderLink href={item.href} aria-label={item.name} title={item.name}>
						<Icon name={`mdi:${item.icon}`} width={20} height={20} aria-hidden="true" />
					</HeaderLink>
				))}
			</div>
		</div>
	</nav>
</header>
<script is:inline>
	(function () {
		function normalize(path) {
			// 去掉 base 路径前缀，与 SSR 时 HeaderLink 的判断保持一致
			try {
				const base = (document.querySelector('base')?.getAttribute('href') || '').replace(/\/$/, '');
				if (base && path.startsWith(base)) path = path.slice(base.length);
			} catch (e) { /* noop */ }
			return path;
		}

		function getFirstSegment(path) {
			const m = path.match(/[^\/]+/g);
			return m ? '/' + m[0] : '/';
		}

		function updateActiveLinks() {
			const pathname = normalize(location.pathname);
			const subpath = getFirstSegment(pathname);
			// 选 header 内的全部 a：MENU_ITEMS 链接
			const links = document.querySelectorAll('header a');
			links.forEach((a) => {
				const href = a.getAttribute('href') || '';
				// 跳过纯 hash 链接（如 Skip to main content）
				if (href.startsWith('#')) return;
				const isActive = href === pathname || href === subpath;
				a.classList.toggle('active', isActive);
			});
		}

		// 视图过渡后重算高亮
		document.addEventListener('astro:after-swap', updateActiveLinks);
		// 首屏进入时也跑一次（处理浏览器前进/后退恢复 bfcache）
		updateActiveLinks();
	})();
</script>
<style>
	header {
		margin: 0;
		padding: 0 1em;
	}
	nav {
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.nav-inner {
		position: relative;
		width: 100%;
		max-width: 720px;
		display: flex;
		justify-content: flex-start;
		align-items: center;
	}
	.nav-left {
		position: absolute;
		right: 0;
		top: 50%;
		transform: translateY(-50%);
		display: flex;
		align-items: center;
		gap: 0.25rem;
		z-index: 10;
	}
	nav a {
		color: var(--nav-text);
		text-decoration: none;
	}
	.internal-links a {
		padding: 0.5em;
		border-bottom: 2px solid transparent;
		transition: color 0.3s ease;
		display: inline-flex;
		align-items: center;
	}
	.internal-links a.active {
		border-bottom-color: var(--accent);
	}
	.internal-links {
		display: flex;
		gap: 0.25rem;
		align-items: center;
	}
	.search-link {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.5rem;
		border-radius: 0.375rem;
		color: var(--nav-text);
		transition: background-color 0.2s ease, color 0.2s ease;
	}
	.search-link:hover {
		background-color: rgba(var(--gray), 10%);
		color: var(--accent);
	}
	.search-link:focus {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	/* Mobile */
	@media (max-width: 900px) {
		.nav-left {
			position: static;
			transform: none;
			order: 1;
			margin-left: auto;
		}
	}

	/* Skip link styles */
	.skip-link {
		position: absolute;
		left: -9999px;
		z-index: 999;
		padding: 1em;
		background-color: var(--accent);
		color: var(--accent-text);
		text-decoration: none;
		font-weight: 600;
		border-radius: 0 0 4px 0;
	}

	.skip-link:focus {
		left: 0;
		top: 0;
	}
</style>
