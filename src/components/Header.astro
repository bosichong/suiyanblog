---
import { SITE_TITLE, MENU_ITEMS } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header transition:persist>
	<a href="#main" class="skip-link">Skip to main content</a>
	<nav>
		<div class="site-title"><a href="/">{SITE_TITLE}</a></div>

		<div class="nav-container">
			<div class="internal-links" id="nav-menu">
				{MENU_ITEMS.map(item => (
					<HeaderLink href={item.href}>
						{item.name}
					</HeaderLink>
				))}
				<div class="mobile-theme-toggle">
					<ThemeToggle />
				</div>
			</div>
			<div class="desktop-theme-toggle">
				<ThemeToggle />
			</div>
		</div>

		<button class="hamburger" id="hamburger-menu" aria-label="Open navigation menu" aria-controls="nav-menu" aria-expanded="false">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</nav>
</header>
<script is:inline>
	(function () {
		function normalize(path) {
			// 去掉 base 路径前缀，与 SSR 时 HeaderLink 的判断保持一致
			try {
				const base = (document.querySelector('base')?.getAttribute('href') || '').replace(/\/$/, '');
				if (base && path.startsWith(base)) path = path.slice(base.length);
			} catch (e) { /* noop */ }
			return path;
		}

		function getFirstSegment(path) {
			const m = path.match(/[^\/]+/g);
			return m ? '/' + m[0] : '/';
		}

		function updateActiveLinks() {
			const pathname = normalize(location.pathname);
			const subpath = getFirstSegment(pathname);
			// 选 header 内的全部 a：MENU_ITEMS 链接 + site-title 首页链接
			const links = document.querySelectorAll('header a');
			links.forEach((a) => {
				const href = a.getAttribute('href') || '';
				// 跳过纯 hash 链接（如 Skip to main content）
				if (href.startsWith('#')) return;
				const isActive = href === pathname || href === subpath;
				a.classList.toggle('active', isActive);
			});
		}

		// 视图过渡后重算高亮
		document.addEventListener('astro:after-swap', updateActiveLinks);
		// 首屏进入时也跑一次（处理浏览器前进/后退恢复 bfcache）
		updateActiveLinks();
	})();

	(function () {
		function getMenuEls() {
			return {
				hamburger: document.getElementById('hamburger-menu'),
				navMenu: document.getElementById('nav-menu'),
			};
		}

		function openMenu() {
			const { hamburger, navMenu } = getMenuEls();
			if (!hamburger || !navMenu) return;
			hamburger.classList.add('open');
			hamburger.setAttribute('aria-expanded', 'true');
			navMenu.classList.add('open');
		}

		function closeMenu() {
			const { hamburger, navMenu } = getMenuEls();
			if (!hamburger || !navMenu) return;
			hamburger.classList.remove('open');
			hamburger.setAttribute('aria-expanded', 'false');
			navMenu.classList.remove('open');
		}

		function toggleMenu() {
			const { navMenu } = getMenuEls();
			if (!navMenu) return;
			navMenu.classList.contains('open') ? closeMenu() : openMenu();
		}

		// 委托到 document，每次都查最新的 DOM 元素
		document.addEventListener('click', (e) => {
			const { hamburger, navMenu } = getMenuEls();
			if (!hamburger || !navMenu) return;

			// 1) 点击汉堡按钮
			if (hamburger.contains(e.target)) {
				e.stopPropagation();
				toggleMenu();
				return;
			}

			// 2) 点击菜单内的链接
			if (navMenu.contains(e.target) && (e.target.tagName === 'A' || e.target.closest('a'))) {
				closeMenu();
				return;
			}

			// 3) 点击外部
			if (!navMenu.contains(e.target) && !hamburger.contains(e.target)) {
				closeMenu();
			}
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') closeMenu();
		});
	})();

	// 滚动激活 header 毛玻璃
	(function () {
		const onScroll = () => {
			const header = document.querySelector('header');
			if (header) header.classList.toggle('scrolled', window.scrollY > 20);
		};
		window.addEventListener('scroll', onScroll, { passive: true });
		onScroll();
		document.addEventListener('astro:after-swap', onScroll);
	})();
</script>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 1em;
		background: var(--header-bg);
		border-bottom: 1px solid transparent;
		backdrop-filter: blur(0);
		-webkit-backdrop-filter: blur(0);
		transition:
			background-color 0.25s ease,
			border-color 0.25s ease,
			backdrop-filter 0.25s ease;
	}
	header.scrolled {
		background: color-mix(in srgb, var(--bg) 85%, transparent);
		border-bottom-color: var(--border);
		backdrop-filter: saturate(180%) blur(12px);
		-webkit-backdrop-filter: saturate(180%) blur(12px);
	}
	.site-title {
		margin: 0;
		font-size: 1.5em;
		font-weight: 700;
	}

	.site-title a,
	.site-title a.active {
		text-decoration: none;
		border-bottom: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--nav-text);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		transition: color 0.3s ease;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.nav-container {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	/* Default (desktop) navigation layout */
	.internal-links {
		display: flex;
		gap: 0.25rem;
		align-items: center;
	}

	.mobile-theme-toggle {
		display: none;
	}

	.desktop-theme-toggle {
		display: block;
	}

	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		width: 40px;
		height: 40px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		margin-left: 1em;
		z-index: 20;
	}
	.hamburger span {
		display: block;
		width: 28px;
		height: 3px;
		margin: 4px 0;
		background: var(--nav-text);
		border-radius: 2px;
		transition: all 0.25s ease;
	}
	.hamburger.open span:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.hamburger.open span:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}
	.hamburger.open span:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}
	@media (max-width: 900px) {
		.hamburger {
			display: flex;
		}
		.nav-container {
			position: static;
			gap: 1rem;
		}
		.desktop-theme-toggle {
			display: none;
		}
		.mobile-theme-toggle {
			display: block;
			padding: 0.6em 2em;
			border-bottom: 1px solid var(--border-color);
		}
		.internal-links {
			position: absolute;
			top: 60px;
			left: 0;
			right: 0;
			background: var(--header-bg);
			flex-direction: column;
			align-items: flex-start;
			gap: 0;
			display: none;
			z-index: 10;
			box-shadow: 0 2px 8px rgba(var(--black), 10%);
		}
		.internal-links.open {
			display: flex;
		}
		.internal-links a {
			width: 100%;
			padding: 0.6em 2em;
			border-bottom: 1px solid var(--border-color);
		}
	}
	@media (max-width: 720px) {
		.internal-links {
			top: 50px;
		}
	}
	
	/* Skip link styles */
	.skip-link {
		position: absolute;
		left: -9999px;
		z-index: 999;
		padding: 1em;
		background-color: var(--accent);
		color: white;
		text-decoration: none;
		font-weight: 600;
		border-radius: 0 0 4px 0;
	}
	
	.skip-link:focus {
		left: 0;
		top: 0;
	}
</style>
