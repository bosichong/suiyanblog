---
import { MENU_ITEMS } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header transition:persist>
	<a href="#main" class="skip-link">Skip to main content</a>
	<nav>
		<div class="nav-inner">
			<div class="internal-links" id="nav-menu">
				{MENU_ITEMS.map(item => (
					<HeaderLink href={item.href}>
						{item.name}
					</HeaderLink>
				))}
			</div>
		</div>
		<div class="theme-toggle">
			<ThemeToggle />
		</div>
		<button class="hamburger" id="hamburger-menu" aria-label="Open navigation menu" aria-controls="nav-menu" aria-expanded="false">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</nav>
</header>
<script is:inline>
	(function () {
		function normalize(path) {
			// 去掉 base 路径前缀，与 SSR 时 HeaderLink 的判断保持一致
			try {
				const base = (document.querySelector('base')?.getAttribute('href') || '').replace(/\/$/, '');
				if (base && path.startsWith(base)) path = path.slice(base.length);
			} catch (e) { /* noop */ }
			return path;
		}

		function getFirstSegment(path) {
			const m = path.match(/[^\/]+/g);
			return m ? '/' + m[0] : '/';
		}

		function updateActiveLinks() {
			const pathname = normalize(location.pathname);
			const subpath = getFirstSegment(pathname);
			// 选 header 内的全部 a：MENU_ITEMS 链接
			const links = document.querySelectorAll('header a');
			links.forEach((a) => {
				const href = a.getAttribute('href') || '';
				// 跳过纯 hash 链接（如 Skip to main content）
				if (href.startsWith('#')) return;
				const isActive = href === pathname || href === subpath;
				a.classList.toggle('active', isActive);
			});
		}

		// 视图过渡后重算高亮
		document.addEventListener('astro:after-swap', updateActiveLinks);
		// 首屏进入时也跑一次（处理浏览器前进/后退恢复 bfcache）
		updateActiveLinks();
	})();

	(function () {
		function getMenuEls() {
			return {
				hamburger: document.getElementById('hamburger-menu'),
				navMenu: document.getElementById('nav-menu'),
			};
		}

		function openMenu() {
			const { hamburger, navMenu } = getMenuEls();
			if (!hamburger || !navMenu) return;
			hamburger.classList.add('open');
			hamburger.setAttribute('aria-expanded', 'true');
			navMenu.classList.add('open');
		}

		function closeMenu() {
			const { hamburger, navMenu } = getMenuEls();
			if (!hamburger || !navMenu) return;
			hamburger.classList.remove('open');
			hamburger.setAttribute('aria-expanded', 'false');
			navMenu.classList.remove('open');
		}

		function toggleMenu() {
			const { navMenu } = getMenuEls();
			if (!navMenu) return;
			navMenu.classList.contains('open') ? closeMenu() : openMenu();
		}

		// 委托到 document，每次都查最新的 DOM 元素
		document.addEventListener('click', (e) => {
			const { hamburger, navMenu } = getMenuEls();
			if (!hamburger || !navMenu) return;

			// 1) 点击汉堡按钮
			if (hamburger.contains(e.target)) {
				e.stopPropagation();
				toggleMenu();
				return;
			}

			// 2) 点击菜单内的链接
			if (navMenu.contains(e.target) && (e.target.tagName === 'A' || e.target.closest('a'))) {
				closeMenu();
				return;
			}

			// 3) 点击外部
			if (!navMenu.contains(e.target) && !hamburger.contains(e.target)) {
				closeMenu();
			}
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') closeMenu();
		});
	})();
</script>
<style>
	header {
		margin: 0;
		padding: 0 1em;
	}
	nav {
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.nav-inner {
		width: 100%;
		max-width: 720px;
	}
	nav a {
		padding: 1em 0.5em 0.25em;
		color: var(--nav-text);
		border-bottom: 2px solid transparent;
		text-decoration: none;
		transition: color 0.3s ease;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.internal-links {
		display: flex;
		gap: 0.25rem;
		align-items: center;
	}
	.theme-toggle {
		position: absolute;
		right: 0;
		top: 50%;
		transform: translateY(-50%);
		z-index: 10;
	}
	.hamburger {
		display: none;
	}

	/* Mobile */
	@media (max-width: 900px) {
		nav {
			justify-content: space-between;
		}
		.nav-inner {
			max-width: none;
			width: auto;
		}
		.theme-toggle {
			position: static;
			transform: none;
			order: 1;
		}
		.hamburger {
			display: flex;
			order: -1;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			width: 40px;
			height: 40px;
			background: none;
			border: none;
			cursor: pointer;
			padding: 0;
			z-index: 20;
		}
		.hamburger span {
			display: block;
			width: 28px;
			height: 3px;
			margin: 4px 0;
			background: var(--nav-text);
			border-radius: 2px;
			transition: all 0.25s ease;
		}
		.hamburger.open span:nth-child(1) {
			transform: translateY(7px) rotate(45deg);
		}
		.hamburger.open span:nth-child(2) {
			opacity: 0;
			transform: scaleX(0);
		}
		.hamburger.open span:nth-child(3) {
			transform: translateY(-7px) rotate(-45deg);
		}
		.internal-links {
			position: absolute;
			top: 100%;
			left: -1em;
			right: -1em;
			background: var(--header-bg);
			flex-direction: column;
			align-items: flex-start;
			gap: 0;
			display: none;
			z-index: 10;
			box-shadow: 0 2px 8px rgba(var(--black), 10%);
		}
		.internal-links.open {
			display: flex;
		}
		.internal-links a {
			width: 100%;
			padding: 0.6em 2em;
			border-bottom: 1px solid var(--border-color);
		}
	}

	/* Skip link styles */
	.skip-link {
		position: absolute;
		left: -9999px;
		z-index: 999;
		padding: 1em;
		background-color: var(--accent);
		color: white;
		text-decoration: none;
		font-weight: 600;
		border-radius: 0 0 4px 0;
	}

	.skip-link:focus {
		left: 0;
		top: 0;
	}
</style>
