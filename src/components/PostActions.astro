---
import { COMMENTS_CONFIG } from '../consts';

interface Props {
	postId: string;
	postPath: string;
}

const { postId, postPath } = Astro.props;

// 将配置序列化为 JSON 供客户端使用
const commentsConfig = JSON.stringify(COMMENTS_CONFIG);
---

<div class="comment-section" id="comment-section" data-post-id={postId} data-post-path={postPath} data-config={commentsConfig}>
	<div class="comment-selector">
		<button class="comment-type-btn" data-type="giscus">💭 GitHub 讨论</button>
		<button class="comment-type-btn" data-type="twikoo">💬 Twikoo 评论</button>
	</div>
	<div class="comment-content" id="comment-content">
		<!-- 评论内容由 JS 动态加载 -->
	</div>
</div>

<style>
	.comment-section {
		margin: 2rem 0;
		padding: 1.5rem;
		background: var(--header-bg);
		border-radius: 12px;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	
	.comment-selector {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}
	
	.comment-type-btn {
		padding: 0.75rem 1.5rem;
		border: 2px solid var(--border-color);
		border-radius: 8px;
		background: var(--bg-color);
		color: var(--text-color);
		cursor: pointer;
		font-size: 0.95rem;
		transition: all 0.2s ease;
	}
	
	.comment-type-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	
	.comment-type-btn.active {
		background: var(--accent);
		color: white;
		border-color: var(--accent);
	}
	
	.comment-content {
		margin-top: 1rem;
		min-height: 0;
	}
	
	@media (max-width: 480px) {
		.comment-selector {
			flex-direction: column;
		}
		
		.comment-type-btn {
			width: 100%;
		}
	}
</style>

<script>
	const commentSection = document.getElementById('comment-section');
	const commentContent = document.getElementById('comment-content');
	const commentTypeBtns = document.querySelectorAll('.comment-type-btn');
	
	// 从 data-config 读取配置
	const configStr = commentSection?.getAttribute('data-config') || '{}';
	const config = JSON.parse(configStr);
	
	let currentType: string | null = null;
	let giscusLoaded = false;
	
	// 点击评论类型按钮
	commentTypeBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			const type = btn.getAttribute('data-type');
			if (!type) return;
			
			// 如果已经加载了同类型，不做任何操作
			if (type === currentType) return;
			
			// 更新按钮状态
			commentTypeBtns.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');
			
			// 清空内容
			if (commentContent) {
				commentContent.innerHTML = '';
			}
			
			currentType = type;
			loadComments(type);
		});
	});
	
	function loadComments(type: string) {
		if (!commentContent) return;
		
		const postId = commentSection?.getAttribute('data-post-id') || '';
		const postPath = commentSection?.getAttribute('data-post-path') || '';
		
		if (type === 'giscus') {
			loadGiscus(postId);
		} else {
			loadTwikoo(postPath);
		}
	}
	
	function loadGiscus(postId: string) {
		if (!commentContent) return;
		
		const theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
		
		// 创建 giscus 容器
		const giscusContainer = document.createElement('div');
		giscusContainer.className = 'giscus';
		commentContent.appendChild(giscusContainer);
		
		// 创建 script 元素
		const script = document.createElement('script');
		script.src = 'https://giscus.app/client.js';
		script.setAttribute('data-repo', config.giscus.repo);
		script.setAttribute('data-repo-id', config.giscus.repoId);
		script.setAttribute('data-category', config.giscus.category);
		script.setAttribute('data-category-id', config.giscus.categoryId);
		script.setAttribute('data-mapping', config.giscus.mapping);
		script.setAttribute('data-lang', config.giscus.lang);
		script.setAttribute('data-strict', '0');
		script.setAttribute('data-reactions-enabled', '1');
		script.setAttribute('data-emit-metadata', '0');
		script.setAttribute('data-input-position', 'bottom');
		script.setAttribute('data-theme', theme);
		script.setAttribute('crossorigin', 'anonymous');
		script.async = true;
		
		giscusContainer.appendChild(script);
		giscusLoaded = true;
	}
	
	function loadTwikoo(path: string) {
		if (!commentContent) return;
		
		commentContent.innerHTML = '<div id="twikoo-comment" style="min-height: 200px;"></div>';
		
		// 检查是否已加载 Twikoo
		if ((window as any).twikoo) {
			(window as any).twikoo.init({
				envId: config.twikoo.envId,
				el: '#twikoo-comment',
				path: path
			});
			return;
		}
		
		// 加载 Twikoo 脚本
		const script = document.createElement('script');
		script.src = 'https://cdn.jsdelivr.net/npm/twikoo@1.7.4/dist/twikoo.all.min.js';
		script.async = true;
		script.onload = () => {
			(window as any).twikoo?.init({
				envId: config.twikoo.envId,
				el: '#twikoo-comment',
				path: path
			});
		};
		document.head.appendChild(script);
	}
	
	// 监听主题变化，更新 Giscus 主题
	const observer = new MutationObserver(() => {
		if (!giscusLoaded || currentType !== 'giscus') return;
		
		const theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
		const iframe = commentContent?.querySelector('iframe.giscus-frame');
		if (iframe) {
			iframe.contentWindow?.postMessage(
				{ giscus: { setConfig: { theme } } },
				'https://giscus.app'
			);
		}
	});
	
	observer.observe(document.documentElement, {
		attributes: true,
		attributeFilter: ['data-theme']
	});
</script>