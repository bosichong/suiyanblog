---
import { COMMENTS_CONFIG } from '../consts';

interface Props {
	postId: string;
	postPath: string;
}

const { postId, postPath } = Astro.props;

// 将配置序列化为 JSON 供客户端使用
const commentsConfig = JSON.stringify(COMMENTS_CONFIG);
---

<div class="comment-section" id="comment-section" data-post-id={postId} data-post-path={postPath} data-config={commentsConfig}>
	<div class="comment-selector">
		<button class="comment-type-btn" data-type="giscus">💭 GitHub 讨论</button>
		<button class="comment-type-btn" data-type="twikoo">💬 Twikoo 评论</button>
	</div>
	<div class="comment-content" id="comment-content">
		<!-- 评论内容由 JS 动态加载 -->
	</div>
</div>

<style>
	.comment-section {
		margin: 2rem 0;
		padding: 1.5rem;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 12px;
	}

	.comment-selector {
		display: flex;
		gap: 0.5rem;
		justify-content: center;
		padding: 4px;
		background: var(--bg-soft);
		border-radius: 10px;
		max-width: fit-content;
		margin: 0 auto;
	}

	.comment-type-btn {
		padding: 0.5rem 1.25rem;
		border: 1px solid transparent;
		border-radius: 7px;
		background: transparent;
		color: var(--text-soft);
		cursor: pointer;
		font-size: 0.9rem;
		font-weight: 500;
		font-family: inherit;
		transition: all 0.2s ease;
	}

	.comment-type-btn:hover {
		color: var(--accent-dark);
	}

	.comment-type-btn.active {
		background: var(--bg);
		color: var(--accent-dark);
		border-color: var(--border);
		box-shadow: var(--shadow-sm);
	}

	.comment-content {
		margin-top: 1rem;
		min-height: 0;
	}

	@media (max-width: 480px) {
		.comment-selector {
			flex-direction: row;
			width: 100%;
		}

		.comment-type-btn {
			flex: 1;
			text-align: center;
		}
	}
</style>

<script>
	// ============================================================
	// 使用事件委托处理评论按钮点击，不依赖脚本重新执行，
	// 因此在 ClientRouter 视图过渡后仍能正常工作。
	// ============================================================
	
	// ---------- 全局状态（跨导航重置） ----------
	window.__commentState = window.__commentState || { currentType: null, giscusLoaded: false };
	
	// 视图过渡导航后重置状态，避免跨页面污染。
	// 同时清除 twikoo 全局实例，下次点击强制重新加载脚本，
	// 避免旧实例内部的 DOM 引用失效导致样式丢失。
	document.addEventListener('astro:after-swap', () => {
		window.__commentState.currentType = null;
		window.__commentState.giscusLoaded = false;
		delete (window as any).twikoo;
	});
	
	// ---------- 事件委托：按钮点击 ----------
	document.addEventListener('click', (e) => {
		const btn = (e.target as HTMLElement).closest('.comment-type-btn') as HTMLElement | null;
		if (!btn) return;
		
		const section = document.getElementById('comment-section');
		if (!section || !section.contains(btn)) return;
		
		const content = document.getElementById('comment-content');
		if (!content) return;
		
		const type = btn.getAttribute('data-type');
		if (!type) return;
		if (type === window.__commentState.currentType) return;
		
		// 更新按钮状态
		section.querySelectorAll('.comment-type-btn').forEach(b => b.classList.remove('active'));
		btn.classList.add('active');
		
		// 清空内容
		content.innerHTML = '';
		window.__commentState.currentType = type;
		
		// 获取配置（每次从 data-config 读取，确保切换页面后正确）
		const configStr = section.getAttribute('data-config') || '{}';
		const config = JSON.parse(configStr);
		const postId = section.getAttribute('data-post-id') || '';
		const postPath = section.getAttribute('data-post-path') || '';
		
		if (type === 'giscus') {
			loadGiscus(content, config, postId);
		} else {
			loadTwikoo(content, config, postPath);
		}
	});
	
	// ---------- 加载 Giscus ----------
	function loadGiscus(container: HTMLElement, config: any, postId: string) {
		const theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark_dimmed' : 'light';
		
		const giscusContainer = document.createElement('div');
		giscusContainer.className = 'giscus';
		container.appendChild(giscusContainer);
		
		const script = document.createElement('script');
		script.src = 'https://giscus.app/client.js';
		script.setAttribute('data-repo', config.giscus.repo);
		script.setAttribute('data-repo-id', config.giscus.repoId);
		script.setAttribute('data-category', config.giscus.category);
		script.setAttribute('data-category-id', config.giscus.categoryId);
		script.setAttribute('data-mapping', config.giscus.mapping);
		script.setAttribute('data-lang', config.giscus.lang);
		script.setAttribute('data-strict', '0');
		script.setAttribute('data-reactions-enabled', '1');
		script.setAttribute('data-emit-metadata', '0');
		script.setAttribute('data-input-position', 'bottom');
		script.setAttribute('data-theme', theme);
		script.setAttribute('crossorigin', 'anonymous');
		script.async = true;
		
		giscusContainer.appendChild(script);
		window.__commentState.giscusLoaded = true;
	}
	
	// ---------- 加载 Twikoo ----------
	function loadTwikoo(container: HTMLElement, config: any, path: string) {
		// 用 appendChild 而非 innerHTML 创建容器，避免潜在的渲染问题
		const twikooDiv = document.createElement('div');
		twikooDiv.id = 'twikoo-comment';
		twikooDiv.style.minHeight = '200px';
		container.appendChild(twikooDiv);
		
		// 不缓存 window.twikoo，每次从 CDN 重新加载脚本，
		// 确保实例内部状态与当前页面的 DOM 一致。
		const script = document.createElement('script');
		script.src = 'https://cdn.jsdelivr.net/npm/twikoo@1.7.12/dist/twikoo.all.min.js';
		script.onload = () => {
			(window as any).twikoo?.init({
				envId: config.twikoo.envId,
				el: '#twikoo-comment',
				path: path
			});
		};
		document.head.appendChild(script);
	}
	
	// ---------- 监听主题变化，更新 Giscus 主题 ----------
	// 只在首次运行时注册一次（全局 documentElement 不会变）
	if (!(window as any).__commentThemeObserver) {
		const observer = new MutationObserver(() => {
			if (!window.__commentState.giscusLoaded || window.__commentState.currentType !== 'giscus') return;
			
			const theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark_dimmed' : 'light';
			const content = document.getElementById('comment-content');
			const iframe = content?.querySelector('iframe.giscus-frame');
			if (iframe) {
				(iframe.contentWindow as any)?.postMessage(
					{ giscus: { setConfig: { theme } } },
					'https://giscus.app'
				);
			}
		});
		
		(window as any).__commentThemeObserver = observer;
		observer.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ['data-theme']
		});
	}
</script>